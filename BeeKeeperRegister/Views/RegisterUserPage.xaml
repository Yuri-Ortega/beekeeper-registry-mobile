<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeeKeeperRegister.Views.RegisterUserPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:dxc="http://schemas.devexpress.com/maui"
    xmlns:dxe="clr-namespace:DevExpress.Maui.Editors;assembly=DevExpress.Maui.Editors"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewModels="clr-namespace:BeeKeeperRegister.ViewModels;assembly=BeeKeeperRegister"
    Title="Register Account"
    x:DataType="viewModels:RegisterUserViewModel"
    BackgroundColor="{StaticResource BackgroundColor}"
    Shell.NavBarIsVisible="True">
    <dx:DXScrollView>
        <Grid
            Padding="50"
            RowDefinitions="Auto, Auto, *"
            RowSpacing="15">
            <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto">

                <!--  🔹 STEP INDICATOR  -->
                <ScrollView
                    x:Name="stepScroll"
                    Grid.Row="0"
                    HorizontalScrollBarVisibility="Never"
                    Orientation="Horizontal">

                    <HorizontalStackLayout
                        x:Name="stepContainer"
                        Padding="10"
                        HorizontalOptions="Center"
                        Spacing="12">

                        <Border
                            x:Name="step1"
                            BackgroundColor="#698E49"
                            HeightRequest="30"
                            StrokeShape="15"
                            WidthRequest="30">
                            <Label
                                x:Name="step1Txt"
                                HorizontalOptions="Center"
                                Text="1"
                                TextColor="#E0E0E0"
                                VerticalOptions="Center" />
                        </Border>

                        <BoxView
                            x:Name="line1"
                            BackgroundColor="#979797"
                            HeightRequest="2"
                            WidthRequest="40" />

                        <Border
                            x:Name="step2"
                            BackgroundColor="#979797"
                            HeightRequest="30"
                            StrokeShape="15"
                            WidthRequest="30">
                            <Label
                                x:Name="step2Txt"
                                HorizontalOptions="Center"
                                Text="2"
                                VerticalOptions="Center" />
                        </Border>

                        <BoxView
                            x:Name="line2"
                            BackgroundColor="#979797"
                            HeightRequest="2"
                            WidthRequest="40" />

                        <Border
                            x:Name="step3"
                            BackgroundColor="#979797"
                            HeightRequest="30"
                            StrokeShape="15"
                            WidthRequest="30">
                            <Label
                                x:Name="step3Txt"
                                HorizontalOptions="Center"
                                Text="3"
                                VerticalOptions="Center" />
                        </Border>

                        <BoxView
                            x:Name="line3"
                            BackgroundColor="#979797"
                            HeightRequest="2"
                            WidthRequest="40" />

                        <Border
                            x:Name="step4"
                            BackgroundColor="#979797"
                            HeightRequest="30"
                            StrokeShape="15"
                            WidthRequest="30">
                            <Label
                                x:Name="step4Txt"
                                HorizontalOptions="Center"
                                Text="4"
                                VerticalOptions="Center" />
                        </Border>

                    </HorizontalStackLayout>

                </ScrollView>
                <dx:SlideView
                    x:Name="slideView"
                    Grid.Row="1"
                    Margin="0,0,0,15"
                    AllowAnimation="True"
                    AllowSwipe="False">

                    <dx:SlideView.Items>

                        <!--  STEP 1  -->
                        <Grid RowDefinitions="Auto, *" RowSpacing="10">
                            <Label
                                Grid.Row="0"
                                Padding="5,10"
                                FontSize="20"
                                HorizontalTextAlignment="Start"
                                Text="Account" />

                            <ScrollView Grid.Row="1">
                                <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto">
                                    <dx:TextEdit
                                        Grid.Row="0"
                                        HasError="{Binding ErrUserBool}"
                                        IsErrorIconVisible="False"
                                        LabelText="*Username"
                                        StartIcon="user_icon.png"
                                        Text="{Binding User, Mode=TwoWay}" />

                                    <dx:TextEdit
                                        Grid.Row="1"
                                        ErrorText="{Binding ErrEmailTxt}"
                                        HasError="{Binding ErrEmailBool}"
                                        IsErrorIconVisible="False"
                                        LabelText="*E-mail"
                                        PlaceholderText="name@example.com"
                                        StartIcon="mail.png"
                                        Text="{Binding Email, Mode=TwoWay}" />

                                    <dx:TextEdit
                                        Grid.Row="2"
                                        ErrorText="{Binding ErrContactTxt}"
                                        HasError="{Binding ErrContactBool}"
                                        IsErrorIconVisible="False"
                                        Keyboard="Numeric"
                                        LabelText="*Contact Number"
                                        MaxCharacterCount="11"
                                        MaxCharacterCountOverflowMode="LimitInput"
                                        PlaceholderText="Ex. 0917 123 4567"
                                        StartIcon="phone.png"
                                        Text="{Binding ContactNumber, Mode=TwoWay}" />

                                    <dx:PasswordEdit
                                        Grid.Row="3"
                                        ErrorText="{Binding ErrPassTxt}"
                                        HasError="{Binding ErrPassBool}"
                                        IsErrorIconVisible="False"
                                        LabelText="*Password"
                                        PasswordIconVisibility="Auto"
                                        StartIcon="lock_icon.png"
                                        Text="{Binding Pass, Mode=TwoWay}" />

                                    <dx:PasswordEdit
                                        Grid.Row="4"
                                        ErrorText="{Binding ErrConfPassTxt}"
                                        HasError="{Binding ErrConfPassBool}"
                                        IsErrorIconVisible="False"
                                        LabelText="*Confirm Password"
                                        PasswordIconVisibility="Auto"
                                        StartIcon="lock_icon.png"
                                        Text="{Binding ConfPass, Mode=TwoWay}" />
                                </Grid>
                            </ScrollView>
                        </Grid>


                        <!--  STEP 2  -->
                        <Grid RowDefinitions="Auto, *" RowSpacing="10">
                            <Label
                                Grid.Row="0"
                                Padding="5,10"
                                FontSize="20"
                                HorizontalTextAlignment="Start"
                                Text="Personal Info" />

                            <ScrollView Grid.Row="1">
                                <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto">
                                    <dx:TextEdit
                                        Grid.Row="0"
                                        HasError="{Binding ErrLNBool}"
                                        IsErrorIconVisible="False"
                                        LabelText="*Last Name"
                                        StartIcon="user"
                                        Text="{Binding LN, Mode=TwoWay}" />

                                    <dx:TextEdit
                                        Grid.Row="1"
                                        HasError="{Binding ErrFNBool}"
                                        IsErrorIconVisible="False"
                                        LabelText="*First Name"
                                        StartIcon="user"
                                        Text="{Binding FN, Mode=TwoWay}" />

                                    <dx:TextEdit
                                        Grid.Row="2"
                                        ErrorText="{Binding ErrMNTxt}"
                                        HasError="{Binding ErrMNBool}"
                                        IsErrorIconVisible="False"
                                        LabelText="Middle Name"
                                        StartIcon="user"
                                        Text="{Binding MN, Mode=TwoWay}" />

                                    <dx:TextEdit
                                        Grid.Row="3"
                                        ErrorText="{Binding ErrEXNTxt}"
                                        HasError="{Binding ErrEXNBool}"
                                        IsErrorIconVisible="False"
                                        LabelText="Extension Name"
                                        StartIcon="user"
                                        Text="{Binding EXN, Mode=TwoWay}" />

                                    <dxe:DateEdit
                                        Grid.Row="4"
                                        Date="{Binding Birthday, Mode=TwoWay}"
                                        DateChangedCommand="{Binding BirthdayChangedCommand}"
                                        DisplayFormat="d"
                                        HasError="{Binding ErrBirthdayBool}"
                                        LabelText="Birth Date">
                                        <dxe:DateEdit.PickerHeaderAppearance>
                                            <dxe:CalendarHeaderAppearance BackgroundColor="{StaticResource Action}" HeaderTitleTextColor="{StaticResource Surface}" />
                                        </dxe:DateEdit.PickerHeaderAppearance>
                                        <dxe:DateEdit.PickerDayCellAppearance>
                                            <dxe:CalendarDayCellAppearance TextColor="{StaticResource Label}" />
                                        </dxe:DateEdit.PickerDayCellAppearance>
                                        <dxe:DateEdit.PickerDayOfWeekCellAppearance>
                                            <dxe:CalendarDayOfWeekCellAppearance FontAttributes="Bold,Italic" />
                                        </dxe:DateEdit.PickerDayOfWeekCellAppearance>
                                        <dxe:DateEdit.PickerMonthCellAppearance>
                                            <dxe:CalendarMonthCellAppearance BackgroundColor="Transparent" />
                                        </dxe:DateEdit.PickerMonthCellAppearance>

                                        <dxe:DateEdit.PickerYearCellAppearance>
                                            <dxe:CalendarYearCellAppearance BackgroundColor="Transparent" />
                                        </dxe:DateEdit.PickerYearCellAppearance>
                                    </dxe:DateEdit>

                                    <dx:ComboBoxEdit
                                        Grid.Row="5"
                                        DisplayMember="SexDescription"
                                        HasError="{Binding ErrSexBool}"
                                        ItemsSource="{Binding Sex}"
                                        LabelText="*Sex"
                                        SelectedItem="{Binding SelectedSex, Mode=TwoWay}"
                                        SelectionChangedCommand="{Binding SelectionSexCommand}"
                                        StartIcon="gender_icon.png" />
                                </Grid>
                            </ScrollView>

                        </Grid>


                        <!--  STEP 3  -->
                        <Grid RowDefinitions="Auto, *" RowSpacing="10">
                            <Label
                                Grid.Row="0"
                                Padding="5,10"
                                FontSize="20"
                                HorizontalTextAlignment="Start"
                                Text="Geographic Coordinate" />

                            <ScrollView Grid.Row="1">
                                <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto">
                                    <dx:ComboBoxEdit
                                        Grid.Row="0"
                                        AllowAnimation="True"
                                        DisplayMember="Region"
                                        HasError="{Binding ErrRegionBool}"
                                        ItemsSource="{Binding Region}"
                                        LabelText="*Region"
                                        SelectedItem="{Binding SelectedRegion, Mode=TwoWay}"
                                        SelectionChangedCommand="{Binding SelectionRegionCommand}" />

                                    <dx:ComboBoxEdit
                                        Grid.Row="1"
                                        DisplayMember="ProvinceName"
                                        HasError="{Binding ErrProvinceBool}"
                                        IsEnabled="{Binding IsEnabledProvince}"
                                        ItemsSource="{Binding Province}"
                                        LabelText="*Province"
                                        SelectedItem="{Binding SelectedProvince, Mode=TwoWay}"
                                        SelectionChangedCommand="{Binding SelectionProvinceCommand}" />

                                    <dx:ComboBoxEdit
                                        Grid.Row="2"
                                        DisplayMember="MunCity"
                                        HasError="{Binding ErrMunicipalityBool}"
                                        IsEnabled="{Binding IsEnabledMunicipality}"
                                        ItemsSource="{Binding Municipality}"
                                        LabelText="*Municipality"
                                        SelectedItem="{Binding SelectedMunicipality, Mode=TwoWay}"
                                        SelectionChangedCommand="{Binding SelectionMunicipalityCommand}" />

                                    <dx:ComboBoxEdit
                                        Grid.Row="3"
                                        DisplayMember="BarangayName"
                                        HasError="{Binding ErrBarangayBool}"
                                        IsEnabled="{Binding IsEnabledBarangay}"
                                        ItemsSource="{Binding Barangay}"
                                        LabelText="*Barangay"
                                        SelectedItem="{Binding SelectedBarangay, Mode=TwoWay}"
                                        SelectionChangedCommand="{Binding SelectionBarangayCommand}" />

                                    <Label
                                        Grid.Row="4"
                                        Padding="5,10"
                                        FontSize="20"
                                        HorizontalTextAlignment="Start"
                                        Text="Geographic Coordinate" />


                                    <dx:DXBorder Grid.Row="5" CornerRadius="10">
                                        <Grid RowDefinitions="Auto, Auto" RowSpacing="10">
                                            <Label
                                                Grid.Row="0"
                                                FontSize="15"
                                                Text="{Binding Latitude, Mode=TwoWay, StringFormat='Latitude: {0}'}" />
                                            <Label
                                                Grid.Row="1"
                                                FontSize="15"
                                                Text="{Binding Longitude, Mode=TwoWay, StringFormat='Longitude: {0}'}" />
                                        </Grid>
                                    </dx:DXBorder>
                                    <dx:DXButton
                                        Grid.Row="6"
                                        Margin="0,10,0,0"
                                        Padding="10"
                                        BorderColor="{Binding ErrLocationColor}"
                                        BorderThickness="2"
                                        Command="{Binding MapLocationBtnCommand}"
                                        Content="Select Location"
                                        CornerRadius="10"
                                        FontSize="15"
                                        IsEnabled="{Binding IsEnabledSelectLocation}" />

                                </Grid>
                            </ScrollView>

                        </Grid>


                        <!--  STEP 4  -->
                        <Grid RowDefinitions="Auto, *" RowSpacing="10">
                            <Label
                                Grid.Row="0"
                                Padding="5,10"
                                FontSize="20"
                                HorizontalTextAlignment="Start"
                                Text="BeeKeeper Info" />

                            <ScrollView
                                Grid.Row="1"
                                HorizontalScrollBarVisibility="Never"
                                VerticalScrollBarVisibility="Never">
                                <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto">
                                    <dxe:DateEdit
                                        Grid.Row="0"
                                        Date="{Binding StartBeeKeeping, Mode=TwoWay}"
                                        DateChangedCommand="{Binding StartBeeKeepingChangedCommand}"
                                        DisplayFormat="d"
                                        HasError="{Binding ErrStartBeeKeepingBool}"
                                        LabelText="Start BeeKeeping Date">
                                        <dxe:DateEdit.PickerHeaderAppearance>
                                            <dxe:CalendarHeaderAppearance BackgroundColor="{StaticResource Action}" HeaderTitleTextColor="{StaticResource Surface}" />
                                        </dxe:DateEdit.PickerHeaderAppearance>

                                        <dxe:DateEdit.PickerDayCellAppearance>
                                            <dxe:CalendarDayCellAppearance TextColor="{StaticResource Label}" />
                                        </dxe:DateEdit.PickerDayCellAppearance>
                                        <dxe:DateEdit.PickerDayOfWeekCellAppearance>
                                            <dxe:CalendarDayOfWeekCellAppearance FontAttributes="Bold,Italic" />
                                        </dxe:DateEdit.PickerDayOfWeekCellAppearance>
                                    </dxe:DateEdit>

                                    <dx:DXBorder
                                        Grid.Row="1"
                                        Margin="0,10,0,0"
                                        CornerRadius="10">
                                        <VerticalStackLayout
                                            RadioButtonGroup.GroupName="PMB"
                                            RadioButtonGroup.SelectedValue="{Binding SelectedPMB, Mode=TwoWay}"
                                            Spacing="10">
                                            <Label
                                                FontAttributes="Bold"
                                                Text="*Pactices Migration Beekeeping"
                                                VerticalTextAlignment="Center" />
                                            <RadioButton
                                                Content="Yes"
                                                GroupName="PMB"
                                                Value="Yes" />
                                            <RadioButton
                                                Content="No"
                                                GroupName="PMB"
                                                Value="No" />
                                        </VerticalStackLayout>
                                    </dx:DXBorder>

                                    <dx:TextEdit
                                        Grid.Row="2"
                                        Margin="0,0,0,10"
                                        HasError="{Binding ErrIfYesPMBBool}"
                                        IsEnabled="{Binding IsYesPMBBool}"
                                        IsErrorIconVisible="False"
                                        LabelText="Please Specify:"
                                        MaxCharacterCount="300"
                                        Text="{Binding IfYesPMB, Mode=TwoWay}" />

                                    <dxe:NumericEdit
                                        Grid.Row="3"
                                        HasError="{Binding ErrNoFPBool}"
                                        LabelText="*No Farm Personel"
                                        StartIcon="users.png"
                                        Value="{Binding NoFP}" />

                                    <dx:DXBorder
                                        Grid.Row="4"
                                        Margin="0,10,0,10"
                                        CornerRadius="10">
                                        <VerticalStackLayout
                                            RadioButtonGroup.GroupName="Hobbyist"
                                            RadioButtonGroup.SelectedValue="{Binding SelectedIsHobbyist, Mode=TwoWay}"
                                            Spacing="10">
                                            <Label
                                                FontAttributes="Bold"
                                                Text="*Are you Hobbyist"
                                                VerticalTextAlignment="Center" />
                                            <RadioButton
                                                Content="Yes"
                                                GroupName="Hobbyist"
                                                Value="Yes" />
                                            <RadioButton
                                                Content="No"
                                                GroupName="Hobbyist"
                                                Value="No" />
                                        </VerticalStackLayout>
                                    </dx:DXBorder>

                                </Grid>
                            </ScrollView>
                        </Grid>
                    </dx:SlideView.Items>

                </dx:SlideView>


                <Grid
                    Grid.Row="2"
                    Margin="0,10,0,0"
                    ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                    <dx:DXButton
                        x:Name="backButton"
                        Grid.Column="0"
                        Padding="5,10"
                        Clicked="OnBackClicked"
                        Content="BACK"
                        CornerRadius="10"
                        FontSize="15"
                        Style="{StaticResource ButtonOutlineStyle}" />
                    <dx:DXButton
                        x:Name="nextButton"
                        Grid.Column="1"
                        Padding="5,10"
                        Clicked="OnNextClicked"
                        Content="NEXT"
                        CornerRadius="10"
                        FontSize="15" />
                </Grid>

            </Grid>

            <dx:DXButton
                Grid.Row="1"
                Padding="3,10"
                Command="{Binding BackToLoginCommand}"
                Content="Sign Up"
                Style="{StaticResource ButtonOutlineStyle}" />



        </Grid>
    </dx:DXScrollView>
</ContentPage>










