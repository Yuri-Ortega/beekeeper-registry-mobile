<Application
    x:Class="BeeKeeperRegister.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:handler="clr-namespace:BeeKeeperRegister.Handler;assembly=BeeKeeperRegister"
    xmlns:local="clr-namespace:BeeKeeperRegister">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <handler:ZeroToHeightConverter x:Key="ZeroToHeightConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
